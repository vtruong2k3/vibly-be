PORT=8000

# --- AUTHENTICATION ---
JWT_ACCESS_SECRET="your-access-secret-key-here"
JWT_REFRESH_SECRET="your-refresh-secret-key-here"

# --- DATABASE ---
DATABASE_URL="postgresql://user:password@localhost:5432/vibly?schema=public&sslmode=prefer"
DATABASE_URL_UNPOOLED="postgresql://user:password@localhost:5432/vibly?schema=public&sslmode=prefer"

# --- REDIS (Cache, BullMQ, Socket.IO) ---
REDIS_URL="redis://localhost:6379"

# --- AWS S3 (Media Storage) ---
AWS_REGION="ap-southeast-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="vibly-media"

# --- LIVEKIT (Audio/Video Calls) ---
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""
LIVEKIT_HOST="ws://localhost:7880"
