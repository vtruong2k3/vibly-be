generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String                    @id @default(uuid()) @db.Uuid
  email                   String                    @unique
  username                String                    @unique
  passwordHash            String?                   @map("password_hash")
  authProvider            AuthProvider              @default(LOCAL) @map("auth_provider")
  googleId                String?                   @unique @map("google_id")
  role                    UserRole                  @default(USER)
  status                  UserStatus                @default(ACTIVE)
  emailVerifiedAt         DateTime?                 @map("email_verified_at") @db.Timestamptz(6)
  lastLoginAt             DateTime?                 @map("last_login_at") @db.Timestamptz(6)
  createdAt               DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt               DateTime?                 @map("deleted_at") @db.Timestamptz(6)
  adminAuditLogs          AdminAuditLog[]           @relation("AdminAuditActor")
  callEvents              CallEvent[]               @relation("CallEventActor")
  callParticipants        CallParticipant[]
  initiatedCalls          CallSession[]             @relation("CallInitiator")
  commentReactions        CommentReaction[]
  comments                Comment[]                 @relation("CommentAuthor")
  conversationMembers     ConversationMember[]
  createdConversations    Conversation[]            @relation("ConversationCreator")
  emailVerifications      EmailVerification[]
  feedEdgesActed          FeedEdge[]                @relation("FeedEdgeActor")
  feedEdgesOwned          FeedEdge[]                @relation("FeedEdgeOwner")
  receivedFriendRequests  FriendRequest[]           @relation("FriendRequestAddressee")
  requestedFriendRequests FriendRequest[]           @relation("FriendRequestRequester")
  friendedBy              Friendship[]              @relation("FriendshipsFriend")
  friendships             Friendship[]              @relation("FriendshipsUser")
  ownedMedia              MediaAsset[]              @relation("MediaOwner")
  messageReads            MessageRead[]
  sentMessages            Message[]                 @relation("MessageSender")
  moderationActions       ModerationAction[]        @relation("ModerationModerator")
  notificationActors      Notification[]            @relation("NotificationActor")
  notifications           Notification[]            @relation("NotificationUser")
  passwordResets          PasswordReset[]
  postReactions           PostReaction[]
  postSaves               PostSave[]
  posts                   Post[]                    @relation("PostAuthor")
  profile                 Profile?
  pushTokens              PushToken[]
  reportsFiled            Report[]                  @relation("ReportReporter")
  sessions                Session[]
  blocksReceived          UserBlock[]               @relation("UserBlocksBlocked")
  blocksInitiated         UserBlock[]               @relation("UserBlocksBlocker")
  notificationSettings    UserNotificationSettings?
  presence                UserPresence?
  privacySettings         UserPrivacySettings?
  securitySettings        UserSecuritySettings?
  // Admin TOTP 2FA
  totpSecret              String?                   @map("totp_secret")
  totpEnabled             Boolean                   @default(false) @map("totp_enabled")
  totpVerifiedAt          DateTime?                 @map("totp_verified_at") @db.Timestamptz(6)
  totpBackupCodes         AdminTotpBackupCode[]
  // Report relations with admin roles
  reportsModerating       Report[]                  @relation("ReportModerator")
  reportsResolved         Report[]                  @relation("ReportResolver")
  // Auto-Moderation
  createdKeywords         BlacklistedKeyword[]      @relation("BlacklistedKeywordCreator")

  @@index([status])
  @@index([createdAt])
  @@map("users")
}

model Profile {
  userId        String      @id @map("user_id") @db.Uuid
  displayName   String      @map("display_name") @db.VarChar(100)
  bio           String?     @db.VarChar(500)
  gender        String?     @db.VarChar(50)
  birthday      DateTime?   @db.Date
  avatarMediaId String?     @map("avatar_media_id") @db.Uuid
  coverMediaId  String?     @map("cover_media_id") @db.Uuid
  hometown      String?     @db.VarChar(120)
  currentCity   String?     @map("current_city") @db.VarChar(120)
  website       String?     @db.VarChar(255)
  education     String?     @db.VarChar(255)
  maritalStatus String?     @map("marital_status") @db.VarChar(50)
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  avatarMedia   MediaAsset? @relation("ProfileAvatarMedia", fields: [avatarMediaId], references: [id])
  coverMedia    MediaAsset? @relation("ProfileCoverMedia", fields: [coverMediaId], references: [id])
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash")
  deviceName       String?   @map("device_name") @db.VarChar(120)
  deviceOs         String?   @map("device_os") @db.VarChar(120)
  browser          String?   @db.VarChar(120)
  ipCreated        String?   @map("ip_created") @db.Inet
  ipLastUsed       String?   @map("ip_last_used") @db.Inet
  userAgent        String?   @map("user_agent")
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  lastUsedAt       DateTime? @map("last_used_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  revokeReason     String?   @map("revoke_reason") @db.VarChar(120)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt, expiresAt])
  @@index([expiresAt])
  @@map("sessions")
}

model EmailVerification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verifications")
}

model PasswordReset {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  tokenHash   String    @map("token_hash")
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt      DateTime? @map("used_at") @db.Timestamptz(6)
  requestedIp String?   @map("requested_ip") @db.Inet
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_resets")
}

model UserPrivacySettings {
  userId                  String            @id @map("user_id") @db.Uuid
  profileVisibility       PrivacyVisibility @default(FRIENDS) @map("profile_visibility")
  friendListVisibility    PrivacyVisibility @default(FRIENDS) @map("friend_list_visibility")
  allowFriendRequestsFrom AllowFrom         @default(EVERYONE) @map("allow_friend_requests_from")
  allowMessagesFrom       AllowFrom         @default(FRIENDS) @map("allow_messages_from")
  allowCallsFrom          AllowFrom         @default(FRIENDS) @map("allow_calls_from")
  showOnlineStatus        Boolean           @default(true) @map("show_online_status")
  showLastSeen            Boolean           @default(true) @map("show_last_seen")
  createdAt               DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                    User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_privacy_settings")
}

model UserNotificationSettings {
  userId                    String   @id @map("user_id") @db.Uuid
  likeEnabled               Boolean  @default(true) @map("like_enabled")
  commentEnabled            Boolean  @default(true) @map("comment_enabled")
  friendRequestEnabled      Boolean  @default(true) @map("friend_request_enabled")
  messageEnabled            Boolean  @default(true) @map("message_enabled")
  callEnabled               Boolean  @default(true) @map("call_enabled")
  emailNotificationsEnabled Boolean  @default(false) @map("email_notifications_enabled")
  pushNotificationsEnabled  Boolean  @default(true) @map("push_notifications_enabled")
  createdAt                 DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_notification_settings")
}

model UserSecuritySettings {
  userId            String    @id @map("user_id") @db.Uuid
  twoFactorEnabled  Boolean   @default(false) @map("two_factor_enabled")
  passwordChangedAt DateTime? @map("password_changed_at") @db.Timestamptz(6)
  forceReauthAfter  DateTime? @map("force_reauth_after") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_security_settings")
}

model FriendRequest {
  id          String              @id @default(uuid()) @db.Uuid
  requesterId String              @map("requester_id") @db.Uuid
  addresseeId String              @map("addressee_id") @db.Uuid
  status      FriendRequestStatus @default(PENDING)
  respondedAt DateTime?           @map("responded_at") @db.Timestamptz(6)
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  addressee   User                @relation("FriendRequestAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  requester   User                @relation("FriendRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)

  @@index([addresseeId, status, createdAt])
  @@index([requesterId, status, createdAt])
  @@map("friend_requests")
}

model Friendship {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  friendId  String   @map("friend_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  friend    User     @relation("FriendshipsFriend", fields: [friendId], references: [id], onDelete: Cascade)
  user      User     @relation("FriendshipsUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([userId])
  @@index([friendId])
  @@map("friendships")
}

model UserBlock {
  id        String   @id @default(uuid()) @db.Uuid
  blockerId String   @map("blocker_id") @db.Uuid
  blockedId String   @map("blocked_id") @db.Uuid
  reason    String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  blocked   User     @relation("UserBlocksBlocked", fields: [blockedId], references: [id], onDelete: Cascade)
  blocker   User     @relation("UserBlocksBlocker", fields: [blockerId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
  @@map("user_blocks")
}

model MediaAsset {
  id                 String              @id @default(uuid()) @db.Uuid
  ownerUserId        String              @map("owner_user_id") @db.Uuid
  storageProvider    String              @map("storage_provider")
  bucket             String              @db.VarChar(120)
  objectKey          String              @map("object_key")
  originalFilename   String?             @map("original_filename") @db.VarChar(255)
  mimeType           String              @map("mime_type") @db.VarChar(120)
  mediaType          MediaType           @map("media_type")
  sizeBytes          BigInt              @map("size_bytes")
  width              Int?
  height             Int?
  durationSeconds    Int?                @map("duration_seconds")
  checksumSha256     String?             @map("checksum_sha256") @db.VarChar(64)
  status             MediaStatus         @default(READY)
  metadata           Json?
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime?           @map("deleted_at") @db.Timestamptz(6)
  // Media quarantine lifecycle
  storageStatus      MediaStorageStatus  @default(ACTIVE) @map("storage_status")
  quarantinedAt      DateTime?           @map("quarantined_at") @db.Timestamptz(6)
  purgeScheduledAt   DateTime?           @map("purge_scheduled_at") @db.Timestamptz(6)
  purgedAt           DateTime?           @map("purged_at") @db.Timestamptz(6)
  quarantineReason   String?             @map("quarantine_reason")
  restoredAt         DateTime?           @map("restored_at") @db.Timestamptz(6)
  owner              User                @relation("MediaOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  variants           MediaVariant[]
  messageAttachments MessageAttachment[]
  postLinks          PostMedia[]
  avatarForProfiles  Profile[]           @relation("ProfileAvatarMedia")
  coverForProfiles   Profile[]           @relation("ProfileCoverMedia")

  @@unique([bucket, objectKey])
  @@index([ownerUserId, createdAt])
  @@index([status])
  @@index([storageStatus, purgeScheduledAt])
  @@map("media_assets")
}

model MediaVariant {
  id              String     @id @default(uuid()) @db.Uuid
  mediaAssetId    String     @map("media_asset_id") @db.Uuid
  variantType     String     @map("variant_type") @db.VarChar(120)
  bucket          String     @db.VarChar(120)
  objectKey       String     @map("object_key")
  mimeType        String     @map("mime_type") @db.VarChar(120)
  width           Int?
  height          Int?
  sizeBytes       BigInt?    @map("size_bytes")
  durationSeconds Int?       @map("duration_seconds")
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  mediaAsset      MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@unique([mediaAssetId, variantType])
  @@map("media_variants")
}

model Post {
  id            String          @id @default(uuid()) @db.Uuid
  authorUserId  String          @map("author_user_id") @db.Uuid
  content       String?
  visibility    VisibilityLevel @default(FRIENDS)
  status        PostStatus      @default(PUBLISHED)
  commentCount  Int             @default(0) @map("comment_count")
  reactionCount Int             @default(0) @map("reaction_count")
  shareCount    Int             @default(0) @map("share_count")
  publishedAt   DateTime?       @map("published_at") @db.Timestamptz(6)
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?       @map("deleted_at") @db.Timestamptz(6)
  comments      Comment[]
  feedEdges     FeedEdge[]
  media         PostMedia[]
  reactions     PostReaction[]
  saves         PostSave[]
  author        User            @relation("PostAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([authorUserId, createdAt])
  @@index([status, visibility, createdAt])
  @@map("posts")
}

model PostMedia {
  id           String     @id @default(uuid()) @db.Uuid
  postId       String     @map("post_id") @db.Uuid
  mediaAssetId String     @map("media_asset_id") @db.Uuid
  position     Int        @default(0)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  mediaAsset   MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  post         Post       @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, mediaAssetId])
  @@unique([postId, position])
  @@map("post_media")
}

model Comment {
  id              String            @id @default(uuid()) @db.Uuid
  postId          String            @map("post_id") @db.Uuid
  authorUserId    String            @map("author_user_id") @db.Uuid
  parentCommentId String?           @map("parent_comment_id") @db.Uuid
  content         String
  reactionCount   Int               @default(0) @map("reaction_count")
  replyCount      Int               @default(0) @map("reply_count")
  status          CommentStatus     @default(PUBLISHED)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?         @map("deleted_at") @db.Timestamptz(6)
  reactions       CommentReaction[]
  author          User              @relation("CommentAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  parentComment   Comment?          @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies         Comment[]         @relation("CommentReplies")
  post            Post              @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([parentCommentId, createdAt])
  @@index([authorUserId, createdAt])
  @@map("comments")
}

model PostReaction {
  id           String       @id @default(uuid()) @db.Uuid
  postId       String       @map("post_id") @db.Uuid
  userId       String       @map("user_id") @db.Uuid
  reactionType ReactionType @default(LIKE) @map("reaction_type")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  post         Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId, createdAt])
  @@map("post_reactions")
}

model CommentReaction {
  id           String       @id @default(uuid()) @db.Uuid
  commentId    String       @map("comment_id") @db.Uuid
  userId       String       @map("user_id") @db.Uuid
  reactionType ReactionType @default(LIKE) @map("reaction_type")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  comment      Comment      @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@map("comment_reactions")
}

model PostSave {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId, createdAt])
  @@map("post_saves")
}

model FeedEdge {
  id          String   @id @default(uuid()) @db.Uuid
  ownerUserId String   @map("owner_user_id") @db.Uuid
  actorUserId String   @map("actor_user_id") @db.Uuid
  postId      String   @map("post_id") @db.Uuid
  rankScore   Decimal  @default(0) @map("rank_score") @db.Decimal(12, 4)
  source      String   @default("friend_post")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  actor       User     @relation("FeedEdgeActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  owner       User     @relation("FeedEdgeOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([ownerUserId, postId])
  @@index([ownerUserId, rankScore, createdAt])
  @@map("feed_edges")
}

model Conversation {
  id              String               @id @default(uuid()) @db.Uuid
  type            ConversationType     @default(DIRECT)
  createdByUserId String?              @map("created_by_user_id") @db.Uuid
  lastMessageId   String?              @unique @map("last_message_id") @db.Uuid
  lastMessageAt   DateTime?            @map("last_message_at") @db.Timestamptz(6)
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  callSessions    CallSession[]
  members         ConversationMember[]
  createdByUser   User?                @relation("ConversationCreator", fields: [createdByUserId], references: [id])
  lastMessage     Message?             @relation("ConversationLastMessage", fields: [lastMessageId], references: [id])
  messages        Message[]            @relation("ConversationMessages")

  @@map("conversations")
}

model ConversationMember {
  id                String                 @id @default(uuid()) @db.Uuid
  conversationId    String                 @map("conversation_id") @db.Uuid
  userId            String                 @map("user_id") @db.Uuid
  role              ConversationMemberRole @default(MEMBER)
  joinedAt          DateTime               @default(now()) @map("joined_at") @db.Timestamptz(6)
  leftAt            DateTime?              @map("left_at") @db.Timestamptz(6)
  lastReadMessageId String?                @map("last_read_message_id") @db.Uuid
  lastReadAt        DateTime?              @map("last_read_at") @db.Timestamptz(6)
  unreadCount       Int                    @default(0) @map("unread_count")
  isMuted           Boolean                @default(false) @map("is_muted")
  isArchived        Boolean                @default(false) @map("is_archived")
  createdAt         DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  conversation      Conversation           @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  lastReadMessage   Message?               @relation("ConversationMemberLastReadMessage", fields: [lastReadMessageId], references: [id])
  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, updatedAt])
  @@map("conversation_members")
}

model Message {
  id                        String               @id @default(uuid()) @db.Uuid
  conversationId            String               @map("conversation_id") @db.Uuid
  senderUserId              String               @map("sender_user_id") @db.Uuid
  replyToMessageId          String?              @map("reply_to_message_id") @db.Uuid
  messageType               MessageType          @default(TEXT) @map("message_type")
  content                   String?
  status                    MessageStatus        @default(SENT)
  sentAt                    DateTime             @default(now()) @map("sent_at") @db.Timestamptz(6)
  editedAt                  DateTime?            @map("edited_at") @db.Timestamptz(6)
  deletedAt                 DateTime?            @map("deleted_at") @db.Timestamptz(6)
  createdAt                 DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  lastReadByMembers         ConversationMember[] @relation("ConversationMemberLastReadMessage")
  lastMessageOfConversation Conversation?        @relation("ConversationLastMessage")
  attachments               MessageAttachment[]
  reads                     MessageRead[]
  conversation              Conversation         @relation("ConversationMessages", fields: [conversationId], references: [id], onDelete: Cascade)
  replyToMessage            Message?             @relation("MessageReplies", fields: [replyToMessageId], references: [id])
  replies                   Message[]            @relation("MessageReplies")
  sender                    User                 @relation("MessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([conversationId, sentAt])
  @@index([senderUserId, sentAt])
  @@map("messages")
}

model MessageAttachment {
  id           String     @id @default(uuid()) @db.Uuid
  messageId    String     @map("message_id") @db.Uuid
  mediaAssetId String     @map("media_asset_id") @db.Uuid
  position     Int        @default(0)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  mediaAsset   MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  message      Message    @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, mediaAssetId])
  @@map("message_attachments")
}

model MessageRead {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  readAt    DateTime @map("read_at") @db.Timestamptz(6)
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, readAt])
  @@map("message_reads")
}

model UserPresence {
  userId       String    @id @map("user_id") @db.Uuid
  isOnline     Boolean   @default(false) @map("is_online")
  lastSeenAt   DateTime? @map("last_seen_at") @db.Timestamptz(6)
  lastActiveAt DateTime? @map("last_active_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_presence")
}

model CallSession {
  id              String            @id @default(uuid()) @db.Uuid
  conversationId  String?           @map("conversation_id") @db.Uuid
  initiatorUserId String            @map("initiator_user_id") @db.Uuid
  provider        String            @default("livekit")
  roomName        String            @unique @map("room_name") @db.VarChar(255)
  callType        CallType          @map("call_type")
  status          CallStatus        @default(RINGING)
  startedAt       DateTime?         @map("started_at") @db.Timestamptz(6)
  answeredAt      DateTime?         @map("answered_at") @db.Timestamptz(6)
  endedAt         DateTime?         @map("ended_at") @db.Timestamptz(6)
  durationSeconds Int               @default(0) @map("duration_seconds")
  endedReason     String?           @map("ended_reason")
  metadata        Json?
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  events          CallEvent[]
  participants    CallParticipant[]
  conversation    Conversation?     @relation(fields: [conversationId], references: [id])
  initiator       User              @relation("CallInitiator", fields: [initiatorUserId], references: [id], onDelete: Cascade)

  @@index([initiatorUserId, createdAt])
  @@index([conversationId, createdAt])
  @@map("call_sessions")
}

model CallParticipant {
  id              String         @id @default(uuid()) @db.Uuid
  callSessionId   String         @map("call_session_id") @db.Uuid
  userId          String         @map("user_id") @db.Uuid
  role            String         @default("participant") @db.VarChar(50)
  joinStatus      CallJoinStatus @default(INVITED) @map("join_status")
  joinedAt        DateTime?      @map("joined_at") @db.Timestamptz(6)
  leftAt          DateTime?      @map("left_at") @db.Timestamptz(6)
  durationSeconds Int            @default(0) @map("duration_seconds")
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  callSession     CallSession    @relation(fields: [callSessionId], references: [id], onDelete: Cascade)
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([callSessionId, userId])
  @@map("call_participants")
}

model CallEvent {
  id            String      @id @default(uuid()) @db.Uuid
  callSessionId String      @map("call_session_id") @db.Uuid
  actorUserId   String?     @map("actor_user_id") @db.Uuid
  eventType     String      @map("event_type") @db.VarChar(120)
  payload       Json?
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  actor         User?       @relation("CallEventActor", fields: [actorUserId], references: [id])
  callSession   CallSession @relation(fields: [callSessionId], references: [id], onDelete: Cascade)

  @@index([callSessionId, createdAt])
  @@map("call_events")
}

model Notification {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String           @map("user_id") @db.Uuid
  actorUserId String?          @map("actor_user_id") @db.Uuid
  type        NotificationType
  title       String?          @db.VarChar(255)
  body        String?
  entityType  String?          @map("entity_type") @db.VarChar(120)
  entityId    String?          @map("entity_id") @db.Uuid
  isRead      Boolean          @default(false) @map("is_read")
  readAt      DateTime?        @map("read_at") @db.Timestamptz(6)
  deliveredAt DateTime?        @map("delivered_at") @db.Timestamptz(6)
  metadata    Json?
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  actor       User?            @relation("NotificationActor", fields: [actorUserId], references: [id])
  user        User             @relation("NotificationUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

model PushToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  provider   String    @db.VarChar(50)
  token      String
  deviceName String?   @map("device_name") @db.VarChar(120)
  isActive   Boolean   @default(true) @map("is_active")
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, token])
  @@index([userId, isActive])
  @@map("push_tokens")
}

model Report {
  id                String             @id @default(uuid()) @db.Uuid
  reporterUserId    String             @map("reporter_user_id") @db.Uuid
  targetType        ReportTargetType   @map("target_type")
  targetId          String             @map("target_id") @db.Uuid
  reasonCode        String             @map("reason_code") @db.VarChar(120)
  reasonText        String?            @map("reason_text")
  status            ReportStatus       @default(OPEN)
  // Admin moderation extensions
  severity          ReportSeverity     @default(MEDIUM)
  moderatorId       String?            @map("moderator_id") @db.Uuid
  resolvedAt        DateTime?          @map("resolved_at") @db.Timestamptz(6)
  resolvedByUserId  String?            @map("resolved_by_user_id") @db.Uuid
  resolveNote       String?            @map("resolve_note")
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  moderationActions ModerationAction[]
  reporter          User               @relation("ReportReporter", fields: [reporterUserId], references: [id], onDelete: Cascade)
  moderator         User?              @relation("ReportModerator", fields: [moderatorId], references: [id])
  resolvedBy        User?              @relation("ReportResolver", fields: [resolvedByUserId], references: [id])

  @@index([targetType, targetId])
  @@index([status, createdAt])
  @@index([reporterUserId, createdAt])
  @@index([severity, status])
  @@map("reports")
}

model ModerationAction {
  id              String               @id @default(uuid()) @db.Uuid
  reportId        String?              @map("report_id") @db.Uuid
  moderatorUserId String               @map("moderator_user_id") @db.Uuid
  targetType      ReportTargetType     @map("target_type")
  targetId        String               @map("target_id") @db.Uuid
  actionType      ModerationActionType @map("action_type")
  note            String?
  metadata        Json?
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  moderator       User                 @relation("ModerationModerator", fields: [moderatorUserId], references: [id], onDelete: Cascade)
  report          Report?              @relation(fields: [reportId], references: [id])

  @@index([targetType, targetId, createdAt])
  @@index([moderatorUserId, createdAt])
  @@map("moderation_actions")
}

model AdminAuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String   @map("actor_user_id") @db.Uuid
  action      String   @db.VarChar(120)
  entityType  String   @map("entity_type") @db.VarChar(120)
  entityId    String?  @map("entity_id") @db.Uuid
  ip          String?  @db.Inet
  userAgent   String?  @map("user_agent")
  payload     Json?
  reason      String?  @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  actor       User     @relation("AdminAuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([actorUserId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([action, createdAt])
  @@map("admin_audit_logs")
}

model AdminTotpBackupCode {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  codeHash  String    @map("code_hash")
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("admin_totp_backup_codes")
}

